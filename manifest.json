{
  "manifest_version": 3,
  "name": "g3-automator",
  "version": "1.0",
  "description": "auto filler",
  "background": {
    "service_worker": "dist/background.js"
  },
  "permissions": [
    "scripting",
    "clipboardRead",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": [
    "https://*.safaricom.co.ke/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://sp.ke.m-pesa.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "all_frames": true,
      "type": "module"
    },
    {
      "matches": [
        "https://crmsaf.safaricom.co.ke/*"
      ],
      "js": [
        "dist/content-crmsaf.js"
      ]
    }
  ]
}